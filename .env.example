# Environment Variables

# Web3Forms Access Key
# Get your free access key from: https://web3forms.com/
# For development, use a key connected to your test email
# For production (AWS Amplify), use the client's final inbox key
VITE_WEB3FORMS_ACCESS_KEY=

# hCaptcha Site Key (optional)
# Defaults to Web3Forms free plan key (50b2fe65-b00b-4b9e-ad62-3ba471098be2)
# Override if using a custom hCaptcha account or Cloudflare Turnstile
VITE_HCAPTCHA_SITEKEY=

# Site Origin (optional)
# Used for canonical URLs and Open Graph metadata
# Defaults to window.location.origin (current domain)
# Set this in production to ensure correct canonicals: https://a-childs-perspective.com
VITE_SITE_ORIGIN=
